#!/bin/bash

# helper script
# Used to wrap custom operations inside one script
############################# RH helper functions ##############################

ECORP_VERSION=1.1.0

trapERR()
{
	ex=$?
	echo ">> Failing command is '$BASH_COMMAND' on line $BASH_LINENO and status is $ex <<" >&2
	exit $ex
}
trap trapERR ERR

ROOT=$(dirname $(readlink -f $0))

_rh_try_ret_help()
{
	if [ ! -z $RH_RUNTIME_REQUEST_HELP ]
	then
		echo $1
		exit 1;
	fi
}

spawn_default()
{
	cd ${ROOT}
	cd $2
	if ! [ -e $3 ]
	then
		if [ $1 = 'plain' ]
		then
			cp $3'.default' $3
		elif [ $1 = 'eval' ]
		then
			bash <(echo 'cat << EOF' ; cat $3'.default' ; echo 'EOF') > $3
		fi
	fi
	cd ${ROOT}
}

prepare()
{
	_rh_try_ret_help 'Do the necessary preparation steps before launching: spawning default config files, creating directories'
    
	cd ${ROOT}

    mkdir -p data/dns/zones/ data/storage

	spawn_default eval . .env
	spawn_default plain settings ad-users.yml
	spawn_default plain settings steps.yml
}

dc()
{
	docker compose -p ecorp "$@"
}

up()
{
    _rh_try_ret_help 'Starts the infrastructure and follows until ready'
    set -e
    
    cd ${ROOT}

	prepare
    dc up -d --build
	follow_provision
}

follow_provision()
{
	_rh_try_ret_help 'Follow current provisioning process output running in container until the end'
	dc exec controller /ecorp/units/controller/code/ecorp follow_provision
}

provision()
{
	_rh_try_ret_help 'Run provision in controller'
	dc exec controller /ecorp/units/controller/code/ecorp controller_ansible_provision
}

ensure_wrap_base_image()
{
	cd ${ROOT}
	docker build -t ecorp_wrap_base -f dev/ecorp_wrap_base.Dockerfile dev
}

run_in_container()
{
	_rh_try_ret_help 'Launch the ecorp infrastructure in a container'
	
	ensure_wrap_base_image

	cd ${ROOT}
	cd dev/wrap_container
	dc up -d
	cat << EOF | dc exec -T ecorp bash
	set -ex
	/source/ecorp wait_docker_ready
	# disable raw protection prevents accessing containers routed style
	# iptables -t raw -I PREROUTING 1 -j ACCEPT

git config --global --add safe.directory /source/.git
git clone /source ecorp
cd ecorp
./ecorp up

	echo ""
	echo "To make this internal network segment available on host machine, add this route:"
	echo "route add -net \$(source ./.env; echo \$NET_CIDR) gw \$(hostname -i)"
EOF

# cycle in container:
# docker compose down -v ; git clean -fxd ; git pull origin master ; ./ecorp up ; docker logs -f ecorp-controller-1

}

ci_test_infra()
{
	_rh_try_ret_help 'CI/CD: Launch the ecorp infrastructure in a container for testing.'
	ensure_wrap_base_image
	cd ${ROOT}
	cd dev/ci_test
	docker compose -p ci_test up -d --build

	cleanup()
	{
		docker compose -p ci_test down -v || true
		exit 0
	}

	trap cleanup EXIT

	cat << EOF | docker compose -p ci_test exec -T ecorp bash
	set -ex
	cd /ecorp
	./ecorp wait_docker_ready
	./ecorp up
EOF
}

ci_ensure_diorama()
{
	# Build ecorp_diorama if not yet available with current version
	
	IMAGE=ecorp-diorama
	VERSION=$ECORP_VERSION

	if ! docker pull ${REPO}${IMAGE}:${VERSION} || [ ! -z $FORCE_BUILD_IMAGE ]
	then
		
		if [ ! -z $DOCKER_REGISTRY ]
		then
			echo "$DOCKER_REGISTRY_PASSWORD" | docker login $DOCKER_REGISTRY -u $DOCKER_REGISTRY_USERNAME --password-stdin
			export REPO=${DOCKER_REGISTRY}/
		fi

		build_diorama_image

		if [ ! -z ${REPO} ]
		then
			docker push ${REPO}${IMAGE}:${VERSION}
		fi

		# Also set "latest" tag on this image if not prevented
		if [ -z $NOT_LATEST ]
		then
			docker tag ${REPO}${IMAGE}:${VERSION} ${REPO}${IMAGE}:latest
			if [ ! -z ${REPO} ]
			then
			docker push ${REPO}${IMAGE}:latest
			fi
		fi
		else
	echo "Version already present $IMAGE:$VERSION"
	exit 0
	fi
}

wait_docker_ready()
{
	rem=30
	while ! service docker start && ! docker ps && [ $rem '>' 0 ]
	do
		rem=$(expr $rem - 1)
		sleep 1
		echo "Waiting secounds remaining: "$rem
	done
	docker ps
}

inside_diorama__build()
{
	# used only inside image building
	set -ex
	wait_docker_ready

	cd /ecorp
	./ecorp up
	docker buildx prune -af
	service docker stop
	service containerd stop

	mkdir /seed_data
	cp -pfr /var/lib/docker /seed_data/ || true
	cp -pfr /var/lib/containerd /seed_data/ || true
}

inside_diorama__launch()
{
	# On first start
	if ! [ -d /var/lib/docker/containers ]
	then
		cp -pfr /seed_data/docker/* /var/lib/docker
		cp -pfr /seed_data/containerd/* /var/lib/containerd
	fi
	exec /usr/sbin/init
}

build_diorama_image()
{
	_rh_try_ret_help 'Build ecorp-diorama image: an image contains this stack installed and ready to start'
	ensure_wrap_base_image
	cd ${ROOT}

	docker build -t tmp_ecorp_diorama_build_base -f dev/ecorp_diorama_build_base.Dockerfile .

	cleanup()
	{
		docker stop ecorp_diorama_builder_container || true
		docker rm ecorp_diorama_builder_container || true
		docker volume rm ecorp_diorama_builder_docker ecorp_diorama_builder_containerd
		exit 0
	}

	trap cleanup EXIT

	set -ex

	docker run \
	-d \
	-it \
	--cap-add=ALL \
	--security-opt seccomp=unconfined \
	--security-opt apparmor=unconfined \
	--security-opt systempaths=unconfined \
	--tmpfs /tmp \
	--tmpfs /run \
	-v /sys/fs/cgroup:/sys/fs/cgroup \
	-v ecorp_diorama_builder_docker:/var/lib/docker \
	-v ecorp_diorama_builder_containerd:/var/lib/containerd \
	--name ecorp_diorama_builder_container \
		tmp_ecorp_diorama_build_base 

	docker exec ecorp_diorama_builder_container /ecorp/ecorp inside_diorama__build
	docker stop ecorp_diorama_builder_container
	docker commit ecorp_diorama_builder_container ecorp-diorama:$ECORP_VERSION
	docker image tag ecorp-diorama:$ECORP_VERSION ecorp-diorama:latest
}

purge()
{
	_rh_try_ret_help 'Purge the system: stops all container and remove all user files and making git working directory clean as a whistle'
	cd ${ROOT}
	dc down -v
	# git clean -fxd
	# because of git folders (recognised as sub repositories and excluded from clean)
	rm -Rf ./data/*
}

############################ RH built-in functions #############################

help()
{
	_rh_try_ret_help "Returns RH help with the list of all annotated functions"

	echo "RH stands for 'right hand'. It is a wrapper script wherein you can collect tiny commands."
	echo "Specify one righthand function from the followings:"

	RH_RUNTIME_REQUEST_HELP=true

	for f in ${RH_FUNCTIONS[@]}
	do
		# if the command has help
		if type $f | grep -qzP '{\s+_rh_try_ret_help '
		then
			echo -e "\t$f - "$($f)
		fi
	done
}

############################## Application area ################################

# Collection available commands
RH_FUNCTIONS=()

for func in `typeset -F | grep -Po '(?<=-f).*$' | sort`
do
	RH_FUNCTIONS+=($func);
done

# print help if nothing specified

if [ $# '<' '1' ]
then
	help
	exit 1
fi

# run command
for f in ${RH_FUNCTIONS[@]}
do
	if [ "$1" "=" "$f" ]
	then
		$f "${@:2}"
		exit $?
	fi
done

echo "Righthand function $1 not found, so now printing help..."
help
exit 1