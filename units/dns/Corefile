# /etc/coredns/Corefile

. {
    # Serve authoritative zone from a BIND file
    auto . {
        directory /dns/zones/ (.*) {1}
    }

    # Include external forwarding rules
    forward . /etc/resolv.conf

    # Basic logging and health checks
    #log
    errors
    prometheus :9153
    ready
    reload 3s
}